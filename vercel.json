{
  "buildCommand": "cd erp && npm install && npm run build",
  "outputDirectory": "erp/dist",
  "installCommand": "cd erp && npm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
